# ===== App =====
VITE_APP_VERSION=0.9.9.5

# ===== Refresh Mode =====
# auto: 自动刷新; manual: 仅用户触发刷新
VITE_REFRESH_MODE=auto

# ===== Dev Server / Proxy =====
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=3000
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# ===== API =====
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT_MS=10000
VITE_ERROR_TOAST_MIN_INTERVAL_MS=1800
VITE_ERROR_TOAST_DUPLICATE_SUPPRESS_MS=12000

# ===== Auth Endpoints =====
VITE_AUTH_LOGIN_URL=/api/login/
VITE_AUTH_TOKEN_REFRESH_URL=/api/token/refresh/
VITE_AUTH_EMAIL_CODE_ENDPOINT=/register/email/code/
VITE_AUTH_EMAIL_REGISTER_ENDPOINT=/register/email/
VITE_AUTH_PASSWORD_RESET_CODE_ENDPOINT=/password/reset/code/
VITE_AUTH_PASSWORD_RESET_ENDPOINT=/password/reset/

# ===== Investment Endpoints =====
VITE_INVESTMENT_BUY_ENDPOINT=/investment/buy/
VITE_INVESTMENT_SELL_ENDPOINT=/investment/sell/

# ===== Store Auto Refresh =====
VITE_REFRESH_ACCOUNTS_INTERVAL_MINUTES=10
VITE_REFRESH_ACCOUNTS_SECOND=5
VITE_REFRESH_INVESTMENT_INTERVAL_MINUTES=10
VITE_REFRESH_INVESTMENT_SECOND=30
VITE_REFRESH_MARKET_INTERVAL_MINUTES=10
VITE_REFRESH_MARKET_SECOND=30
VITE_MARKET_SELECTED_STORAGE_KEY=market_selected_market

# ===== FX / Dashboard =====
VITE_USD_RATES_ENDPOINT=/user/markets/fx-rates/
VITE_FX_RATES_STALE_MS=600000
VITE_DASHBOARD_DISPLAY_CURRENCY=CNY
VITE_DASHBOARD_DISPLAY_LOCALE=zh-CN
VITE_DASHBOARD_TREND_MAX_RENDER_POINTS=24
VITE_DASHBOARD_TREND_TODAY_MAX_RENDER_POINTS=24
VITE_DASHBOARD_TREND_7D_MAX_RENDER_POINTS=24
VITE_DASHBOARD_TREND_30D_MAX_RENDER_POINTS=24
VITE_DASHBOARD_TREND_1Y_MAX_RENDER_POINTS=24
VITE_DASHBOARD_TREND_ALL_MAX_RENDER_POINTS=24
VITE_REFRESH_DASHBOARD_TREND_INTERVAL_MINUTES=15
VITE_REFRESH_DASHBOARD_TREND_SECOND=20
VITE_POSITION_TREND_MAX_RENDER_POINTS=24
VITE_REFRESH_POSITION_TREND_INTERVAL_MINUTES=15
VITE_REFRESH_POSITION_TREND_SECOND=20

# ===== Search =====
VITE_SEARCH_MARKET_DEBOUNCE_MS=250
VITE_SEARCH_MARKET_CACHE_LIMIT=50
VITE_SEARCH_ADD_POSITION_DEBOUNCE_MS=250
VITE_SEARCH_ADD_POSITION_HIDE_DELAY_MS=120
